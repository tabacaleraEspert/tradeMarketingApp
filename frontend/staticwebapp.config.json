{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/espert-logo-*.png", "/icon-*.png", "/apple-touch-icon.*", "/manifest.json", "/sw.js"]
  },
  "routes": [
    {
      "route": "/api-proxy/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
