# ===========================================
# Azure SQL Database
# ===========================================
# Valores exactos: Azure Portal → SQL databases → tu base → Connection strings

# Opción 1: Variables individuales (recomendado)
DATABASE_SERVER=tu-servidor.database.windows.net
DATABASE_NAME=nombre_bd
DATABASE_USER=usuario_sql
DATABASE_PASSWORD=tu_contraseña

# Timeout de conexión en segundos (si ves "Login timeout expired", prueba 90 o 120)
DATABASE_CONNECTION_TIMEOUT=60

# Solo si el DIT te pide desactivar validación del certificado (no en producción)
# DATABASE_TRUST_SERVER_CERTIFICATE=true

# Opción 2: URL completa (si prefieres)
# DATABASE_URL=mssql+pyodbc://...

# --- Checklist si falla con HYT00 / Login timeout ---
# 1) Azure Portal → SQL servers (el servidor lógico, no solo la BD) → Networking
#    → Firewall: "Add your client IPv4 address" y Guardar.
# 2) Comprueba que DATABASE_SERVER sea *.database.windows.net (sin https://).
# 3) Usuario: en Azure SQL suele ser "adminuser" o "adminuser@tu-servidor" según cómo lo creaste.
# 4) Puerto 1433 saliente no bloqueado (VPN corporativa a veces lo bloquea).

# ===========================================
# Desarrollo local (SQLite)
# ===========================================
# USE_SQLITE=true
# O deja DATABASE_USER y DATABASE_PASSWORD vacíos
