# ===========================================
# Azure SQL Database
# ===========================================
# Servidor: trademarketing.database.windows.net

# Opción 1: Variables individuales (recomendado)
DATABASE_SERVER=trademarketing.database.windows.net
DATABASE_NAME=trademarketingdb
DATABASE_USER=trade
DATABASE_PASSWORD=Marketer!

# Opción 2: URL completa (si prefieres)
# DATABASE_URL=mssql+pyodbc://usuario:contraseña@trademarketing.database.windows.net/TradeMarketing?driver=ODBC+Driver+18+for+SQL+Server

# ===========================================
# Desarrollo local (SQLite)
# ===========================================
# Si Azure falla (error 4060), usa SQLite:
# USE_SQLITE=true
#
# O deja DATABASE_USER y DATABASE_PASSWORD vacíos
