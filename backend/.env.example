# =============================================================================
# Trade Marketing API — Variables de entorno
# =============================================================================
# Copiar a .env y completar con los valores reales.
# En Azure App Service, configurar como Application Settings (no .env).

# --- Base de datos ---
# Para Azure SQL:
DATABASE_SERVER=trade-mkt-sql.database.windows.net
DATABASE_NAME=trademktdb
DATABASE_USER=tu_usuario_sql
DATABASE_PASSWORD=tu_contraseña_sql
DATABASE_CONNECTION_TIMEOUT=60

# Para desarrollo local (SQLite):
# USE_SQLITE=true
# (si se setea, ignora las variables de Azure SQL y usa ./trade_marketing.db)

# --- Auth / JWT ---
# IMPORTANTE: cambiar en producción. Nunca usar el default.
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIAR-ESTO-EN-PRODUCCION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_MINUTES=10080

# --- Storage (fotos) ---
# Si se setea, usa Azure Blob Storage. Si no, fallback a disco local.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=visit-photos

# URL pública del backend (para generar URLs de fotos en modo local)
PUBLIC_BASE_URL=https://espert-trade-api.azurewebsites.net

# --- Observabilidad / Sentry ---
# Dejar vacío para desactivar. Crear cuenta en https://sentry.io/signup/
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
APP_RELEASE=v1.0.0

# --- Checklist si falla la conexión a Azure SQL ---
# 1) Azure Portal → SQL servers → Networking → Firewall: "Add your client IPv4"
# 2) DATABASE_SERVER debe ser *.database.windows.net (sin https://)
# 3) Puerto 1433 saliente no bloqueado (VPN corporativa puede bloquearlo)
